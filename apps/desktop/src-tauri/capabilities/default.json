{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "store:default",
    "dialog:default",
    "sql:default",
    "sql:allow-execute",
    "fs:default",
    "fs:allow-read-dir",
    "fs:allow-stat",
    "fs:allow-read-text-file",
    "fs:allow-rename",
    "fs:allow-remove",
    "fs:allow-write-text-file",
    {
      "identifier": "fs:allow-mkdir",
      "allow": [{ "path": "$HOME/**/.rune" }, { "path": "$DOCUMENT/**/.rune" }]
    },
    "fs:allow-watch",
    "fs:allow-unwatch",
    "fs:scope-document-recursive",
    "fs:scope-home-recursive"
  ]
}
