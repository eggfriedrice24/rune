    "@replit/codemirror-vim": "catalog:",
    "@rune/core": "workspace:*",
    "@rune/db": "workspace:*",
    "@tailwindcss/vite": "catalog:",
    "@tanstack/hotkeys": "catalog:",
    "@tanstack/react-hotkeys": "catalog:",
    "@tauri-apps/api": "catalog:",
