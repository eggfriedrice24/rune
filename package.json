{
  "name": "rune",
  "private": true,
  "description": "A local-first markdown note-taking desktop app with an optional MCP server for AI agents.",
  "keywords": [
    "codemirror",
    "desktop",
    "editor",
    "knowledge-base",
    "local-first",
    "markdown",
    "mcp",
    "model-context-protocol",
    "note-taking",
    "notes",
    "react",
    "tauri",
    "vault"
  ],
  "homepage": "https://github.com/eggfriedrice24/rune#readme",
  "bugs": {
    "url": "https://github.com/eggfriedrice24/rune/issues"
  },
  "license": "MIT",
  "author": "eggfriedrice24 (https://github.com/eggfriedrice24)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eggfriedrice24/rune.git"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@fontsource-variable/inter": "^5.2.8",
      "@hugeicons/core-free-icons": "^4.1.1",
      "@hugeicons/react": "^1.1.6",
      "@tailwindcss/vite": "^4.2.1",
      "@vitejs/plugin-react": "^5.2.0",
      "@codemirror/lang-markdown": "6.5.0",
      "@codemirror/theme-one-dark": "6.1.3",
      "@replit/codemirror-vim": "6.3.0",
      "@tanstack/hotkeys": "0.8.0",
      "@tanstack/react-hotkeys": "0.10.0",
      "@tauri-apps/api": "2.11.0",
      "@tauri-apps/plugin-dialog": "2.7.1",
      "@tauri-apps/plugin-fs": "2.5.1",
      "@tauri-apps/plugin-store": "2.4.3",
      "@types/node": "^24.12.0",
      "@types/react": "^19.2.14",
      "@types/react-dom": "^19.2.3",
      "@uiw/react-codemirror": "4.25.9",
      "react-resizable-panels": "4.11.0",
      "rehype-stringify": "10.0.1",
      "remark-gfm": "4.0.1",
      "remark-parse": "11.0.0",
      "remark-rehype": "11.1.2",
      "unified": "11.0.5",
      "vite": "^7.3.1",
      "react": "^19.2.4",
      "react-dom": "^19.2.4",
      "class-variance-authority": "^0.7.1",
      "clsx": "^2.1.1",
      "radix-ui": "^1.4.3",
      "tailwind-merge": "^3.5.0",
      "tailwindcss": "^4.2.1",
      "tw-animate-css": "^1.4.0",
      "shadcn": "4.7.0",
      "typescript": "~5.9.3",
      "vitest": "4.1.5",
      "zustand": "5.0.13"
    }
  },
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:desktop": "turbo run dev --filter=@rune/desktop",
    "dev:mcp": "turbo run dev --filter=@rune/mcp",
    "tauri:dev": "bun --cwd apps/desktop run tauri:dev",
    "tauri:build": "bun --cwd apps/desktop run tauri:build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "oxlint --report-unused-disable-directives",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules apps/*/dist packages/*/dist .turbo apps/*/.turbo packages/*/.turbo"
  },
  "devDependencies": {
    "oxfmt": "0.48.0",
    "oxlint": "1.63.0",
    "oxlint-tsgolint": "0.22.1",
    "turbo": "2.9.9"
  },
  "engines": {
    "bun": "^1.3.11",
    "node": "^24.0.0"
  },
  "packageManager": "bun@1.3.11"
}
