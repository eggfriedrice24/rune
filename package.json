{
  "name": "rune",
  "private": true,
  "description": "A local-first markdown note-taking desktop app with an optional MCP server for AI agents.",
  "keywords": [
    "codemirror",
    "desktop",
    "editor",
    "knowledge-base",
    "local-first",
    "markdown",
    "mcp",
    "model-context-protocol",
    "note-taking",
    "notes",
    "react",
    "tauri",
    "vault"
  ],
  "homepage": "https://github.com/eggfriedrice24/rune#readme",
  "bugs": {
    "url": "https://github.com/eggfriedrice24/rune/issues"
  },
  "license": "MIT",
  "author": "eggfriedrice24 (https://github.com/eggfriedrice24)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eggfriedrice24/rune.git"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@tauri-apps/api": "2.11.0",
      "@types/node": "^24.12.0",
      "@types/react": "^19.2.14",
      "@types/react-dom": "^19.2.3",
      "react": "^19.2.4",
      "react-dom": "^19.2.4",
      "shadcn": "4.7.0",
      "typescript": "~5.9.3",
      "vitest": "4.1.5"
    }
  },
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:desktop": "turbo run dev --filter=@rune/desktop",
    "dev:mcp": "turbo run dev --filter=@rune/mcp",
    "tauri:dev": "bun --cwd apps/desktop run tauri:dev",
    "tauri:build": "bun --cwd apps/desktop run tauri:build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "oxlint --report-unused-disable-directives",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules apps/*/dist packages/*/dist .turbo apps/*/.turbo packages/*/.turbo"
  },
  "devDependencies": {
    "oxfmt": "0.48.0",
    "oxlint": "1.63.0",
    "oxlint-tsgolint": "0.22.1",
    "turbo": "2.9.9"
  },
  "engines": {
    "bun": "^1.3.11",
    "node": "^24.0.0"
  },
  "packageManager": "bun@1.3.11"
}
